/target
**/*.rs.bk
.DS_Store
web/node_modules

# Never commit secrets — keys live in ~/.revenant/secrets.env (0600)
secrets.env
*.env
!*.example.env

# release artifacts (root-level, from the packaging script). NOTE: this is
# intentionally root-scoped — web/dist IS committed so that a from-source
# `cargo build` (including the Ascension coder) embeds a working web UI without
# needing a Node/Vite toolchain. Rebuild it with `cd web && npm run build`.
/dist/

# Nested workspaces (e.g. wasm example plugins) have their own target dirs
examples/**/target/
**/target/
.claude/settings.local.json

# Stray root fly.toml from `fly launch` — real deploy config is deploy/necropolis/fly.toml
/fly.toml

# Ephemeral coding-job / ascension worktrees (should live outside the repo, but guard anyway)
.revenant-jobs/
.ascension-worktrees/
